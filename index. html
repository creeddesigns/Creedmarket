<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>CreedMarket | Uganda Premium Marketplace</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at 10% 20%, #fff8e8 0%, #e8f3ef 100%);
            color: #1a2e2a;
            line-height: 1.5;
            min-height: 100vh;
        }

        @keyframes aurora {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        
        @keyframes floatIcon {
            0% { transform: translateY(0px); }
            100% { transform: translateY(-6px); }
        }

        .navbar {
            background: rgba(12, 35, 30, 0.92);
            backdrop-filter: blur(16px);
            padding: 1rem 2.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            border-bottom: 1px solid rgba(255, 180, 100, 0.4);
            position: sticky;
            top: 0;
            z-index: 200;
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .logo-icon {
            background: linear-gradient(125deg, #FFB347, #FF6B6B, #4ECDC4);
            background-size: 200% 200%;
            animation: aurora 4s ease infinite;
            width: 54px;
            height: 54px;
            border-radius: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
            box-shadow: 0 8px 18px rgba(0,0,0,0.2);
        }
        .brand-text h1 {
            font-size: 1.9rem;
            background: linear-gradient(135deg, #FFFFFF, #FFD89B);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            font-weight: 800;
        }
        .brand-text p {
            font-size: 0.7rem;
            color: #FFD89B;
        }

        .nav-actions {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
        }
        .nav-btn {
            background: rgba(255,255,245,0.12);
            border: 1px solid rgba(255,200,130,0.3);
            padding: 8px 22px;
            border-radius: 44px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .nav-btn:hover {
            background: linear-gradient(95deg, #FFB347, #FF6B6B);
            color: #1e2a2a;
            transform: translateY(-3px);
        }
        .cart-badge {
            background: linear-gradient(125deg, #FFB347, #FF8C42);
            padding: 8px 22px;
            border-radius: 44px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            cursor: pointer;
            color: white;
        }
        .cart-badge:hover {
            transform: scale(1.02);
        }

        .hero {
            background: linear-gradient(108deg, #fff3e2, #e2f0ea);
            padding: 2.2rem 2rem;
            text-align: center;
        }
        .hero h2 {
            font-size: 2rem;
            background: linear-gradient(125deg, #1F3B34, #E67E22);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            font-weight: 800;
        }
        .search-bar {
            max-width: 640px;
            width: 90%;
            margin: 1.5rem auto 0;
            padding: 14px 28px;
            border-radius: 80px;
            border: none;
            background: rgba(255,255,255,0.9);
            box-shadow: 0 8px 20px rgba(0,0,0,0.05);
            font-size: 1rem;
        }
        .search-bar:focus {
            outline: none;
            box-shadow: 0 0 0 4px rgba(255, 160, 70, 0.4);
        }

        .container {
            max-width: 1400px;
            margin: 2.5rem auto;
            padding: 0 2rem;
        }

        .empty-marketplace {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 48px;
            padding: 3rem;
            text-align: center;
            border: 1px solid rgba(255, 180, 100, 0.5);
        }
        .empty-marketplace i {
            font-size: 4.5rem;
            background: linear-gradient(125deg, #FFB347, #FF6B6B);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            animation: floatIcon 2s infinite alternate;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
            gap: 2rem;
        }
        .product-card {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(8px);
            border-radius: 38px;
            overflow: hidden;
            transition: all 0.35s;
            box-shadow: 0 15px 35px rgba(0,0,0,0.05);
            border: 1px solid rgba(255, 200, 120, 0.5);
        }
        .product-card:hover {
            transform: translateY(-8px);
            background: white;
            border-color: #FFB347;
        }
        .product-img {
            background: linear-gradient(145deg, #fff6ec, #fff0e2);
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4.8rem;
        }
        .product-info {
            padding: 1.3rem;
        }
        .product-title {
            font-weight: 800;
            font-size: 1.25rem;
            color: #1E3A32;
        }
        .vendor-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 12px 0;
            flex-wrap: wrap;
            gap: 10px;
        }
        .vendor-name {
            background: linear-gradient(95deg, #FFF2E6, #FFE6D5);
            padding: 5px 14px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 700;
            color: #C25D00;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .contact-icons {
            display: flex;
            gap: 12px;
        }
        .contact-icons a {
            background: white;
            width: 36px;
            height: 36px;
            border-radius: 30px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            color: #2C5F4E;
            transition: 0.2s;
            border: 1px solid #FFD7A5;
        }
        .contact-icons a:hover {
            background: linear-gradient(135deg, #FFB347, #FF6B6B);
            color: white;
            transform: scale(1.1);
        }
        .price {
            font-size: 1.6rem;
            font-weight: 800;
            background: linear-gradient(125deg, #1F5E4B, #E67E22);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin: 8px 0;
        }
        .add-cart {
            background: linear-gradient(95deg, #1E3A32, #2C5F4E);
            width: 100%;
            border: none;
            padding: 12px;
            border-radius: 48px;
            color: white;
            font-weight: 700;
            margin-top: 12px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        .add-cart:hover {
            background: linear-gradient(95deg, #FFB347, #FF8C42);
            color: #1E2A2A;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(12px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        .modal-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 48px;
            padding: 2rem;
            max-width: 560px;
            width: 90%;
            max-height: 85vh;
            overflow-y: auto;
            border: 1px solid rgba(255, 180, 70, 0.6);
        }
        .modal-card h3 {
            font-size: 1.7rem;
            margin-bottom: 1rem;
            font-weight: 800;
            background: linear-gradient(125deg, #1F3B34, #E67E22);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        input, select, textarea {
            width: 100%;
            padding: 14px 18px;
            margin: 10px 0;
            border-radius: 60px;
            border: 1px solid #FFD7A5;
            font-size: 0.95rem;
        }
        input:focus, select:focus {
            outline: none;
            border-color: #FFB347;
            box-shadow: 0 0 0 3px rgba(255, 160, 70, 0.3);
        }
        button {
            background: linear-gradient(95deg, #1E3A32, #2C5F4E);
            color: white;
            border: none;
            padding: 12px 22px;
            border-radius: 60px;
            font-weight: 700;
            cursor: pointer;
        }
        .approve-btn {
            background: linear-gradient(95deg, #FFB347, #FF8C42);
            color: #1E2A2A;
        }
        footer {
            background: rgba(10, 25, 20, 0.92);
            backdrop-filter: blur(8px);
            color: #B9D2C8;
            text-align: center;
            padding: 2rem;
            margin-top: 3rem;
        }
        .toast-success {
            position: fixed;
            bottom: 25px;
            left: 50%;
            transform: translateX(-50%);
            background: linear-gradient(95deg, #FFB347, #FF8C42);
            color: #1E2A2A;
            padding: 12px 28px;
            border-radius: 60px;
            z-index: 1200;
            font-weight: 700;
        }
        @media (max-width: 680px) {
            .navbar { flex-direction: column; text-align: center; padding: 1rem; }
            .nav-actions { justify-content: center; }
        }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="brand">
        <div class="logo-icon"><i class="fas fa-chart-line"></i></div>
        <div class="brand-text"><h1>CreedMarket</h1><p>Uganda's premium bazaar</p></div>
    </div>
    <div class="nav-actions">
        <button class="nav-btn" id="homeBtnNav"><i class="fas fa-home"></i> Explore</button>
        <button class="nav-btn" id="sellerApplyNav"><i class="fas fa-store"></i> Sell</button>
        <button class="nav-btn" id="vendorDashNav"><i class="fas fa-tachometer-alt"></i> Vendor</button>
        <button class="nav-btn" id="adminNavAccess"><i class="fas fa-user-cog"></i> Admin</button>
        <div class="cart-badge" id="cartBtnHeader"><i class="fas fa-bag-shopping"></i> <span id="cartCountNumber">0</span></div>
    </div>
</nav>

<section class="hero">
    <h2><i class="fas fa-gem"></i> CreedMarket — discover & connect</h2>
    <p style="margin-top: 6px;">Authentic products from verified vendors</p>
    <input type="text" id="globalSearchField" class="search-bar" placeholder="🔍 Search products, vendors or categories...">
</section>

<div class="container"><div id="marketplaceRoot"></div></div>

<footer>
    <p><i class="fas fa-phone-alt"></i> Vendor registration: <strong>0709298041</strong></p>
    <p>© 2025 CreedMarket</p>
</footer>

<!-- Modals -->
<div id="cartModalGlobal" class="modal"><div class="modal-card"><span id="closeCartModal" style="float:right; font-size:1.8rem; cursor:pointer;">&times;</span><h3><i class="fas fa-bag-shopping"></i> Your cart</h3><div id="cartItemsContainer"></div><div id="cartTotalAmount" style="font-weight:bold; margin:1rem 0;"></div><button id="realCheckoutBtn">Confirm order</button><div id="orderStatusMsg"></div></div></div>

<div id="registerSellerModal" class="modal"><div class="modal-card"><span id="closeRegModalBtn" style="float:right; font-size:1.8rem; cursor:pointer;">&times;</span><h3><i class="fas fa-handshake"></i> Join as a merchant</h3><div style="background:linear-gradient(145deg,#FEF3E8,#FFF2E5); border-radius:32px; padding:1rem; margin:1rem 0; text-align:center;"><i class="fas fa-mobile-alt fa-2x" style="color:#E67E22;"></i><p><strong>Registration contribution:</strong></p><span style="font-size:1.8rem; font-weight:800;">5,000 UGX</span><br><small>MTN MoMo / Airtel Money → 0709298041</small></div><input type="text" id="regNameField" placeholder="Business name"><input type="text" id="regPhoneField" placeholder="Phone number"><input type="text" id="regTransactionField" placeholder="Transaction reference"><button id="submitPaymentRequestBtn">Submit request</button><div id="regMessageArea"></div></div></div>

<div id="vendorDashboardModal" class="modal"><div class="modal-card"><span id="closeVendorDash" style="float:right; font-size:1.8rem; cursor:pointer;">&times;</span><h3><i class="fas fa-chart-line"></i> Merchant hub</h3><div id="vendorLoginSection"><input type="text" id="vendorPhoneLoginInput" placeholder="Registered phone"><button id="vendorLoginAction">Access dashboard</button></div><div id="vendorInnerPanel" style="display:none;"><h4>Add new product</h4><input type="text" id="addProdName" placeholder="Product name"><input type="number" id="addProdPrice" placeholder="Price (UGX)"><select id="addProdCategory"><option>Fresh Foods</option><option>Electronics</option><option>Fashion</option><option>Home & Living</option></select><input type="text" id="addProdDesc" placeholder="Description"><input type="text" id="addProdIcon" placeholder="Emoji" value="✨"><button id="publishProductBtn">Publish</button><hr><h4>Your listings</h4><div id="vendorProductsList"></div></div></div></div>

<div id="adminGlobalModal" class="modal"><div class="modal-card"><span id="closeAdminModal" style="float:right; font-size:1.8rem; cursor:pointer;">&times;</span><h3><i class="fas fa-shield-alt"></i> Administration</h3><input type="password" id="adminPasswordInput" placeholder="Admin password"><button id="adminLoginBtnGlobal">Unlock</button><div id="adminSecureContent" style="display:none;"><h4>Pending merchants</h4><div id="pendingVendorsAdminList"></div><h4>Active merchants</h4><div id="approvedVendorsAdminList"></div></div></div></div>

<div id="editPriceModal" class="modal"><div class="modal-card"><span id="closeEditModal" style="float:right; font-size:1.8rem; cursor:pointer;">&times;</span><h3><i class="fas fa-edit"></i> Adjust price</h3><p id="editProductNameDisplay"></p><input type="number" id="editPriceInput" placeholder="New price"><button id="confirmEditPriceBtn">Update</button></div></div>

<script>
    let approvedVendors = JSON.parse(localStorage.getItem('CreedMarket_approvedVendors')) || [];
    let pendingVendors = JSON.parse(localStorage.getItem('CreedMarket_pendingVendors')) || [];
    let allProducts = JSON.parse(localStorage.getItem('CreedMarket_products')) || [];
    let shoppingCart = JSON.parse(localStorage.getItem('CreedMarket_cart')) || [];
    const ADMIN_CODE = "creed123";
    let currentEditProductId = null;

    function syncStorage() {
        localStorage.setItem('CreedMarket_approvedVendors', JSON.stringify(approvedVendors));
        localStorage.setItem('CreedMarket_pendingVendors', JSON.stringify(pendingVendors));
        localStorage.setItem('CreedMarket_products', JSON.stringify(allProducts));
        localStorage.setItem('CreedMarket_cart', JSON.stringify(shoppingCart));
    }

    function showToast(msg) {
        let toast = document.createElement('div');
        toast.className = 'toast-success';
        toast.innerText = msg;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2200);
    }

    function updateCartUI() {
        let total = shoppingCart.reduce((acc, i) => acc + i.quantity, 0);
        document.getElementById('cartCountNumber').innerText = total;
    }

    function getContactButtons(phone) {
        let cleanPhone = phone.replace(/\s+/g, '');
        if (cleanPhone.startsWith('0')) cleanPhone = '256' + cleanPhone.substring(1);
        if (!cleanPhone.startsWith('256')) cleanPhone = '256' + cleanPhone;
        return `<div class="contact-icons"><a href="tel:${cleanPhone}" target="_blank"><i class="fas fa-phone-alt"></i></a><a href="https://wa.me/${cleanPhone}" target="_blank"><i class="fab fa-whatsapp"></i></a></div>`;
    }

    function renderMarketplace() {
        const searchTerm = document.getElementById('globalSearchField')?.value.toLowerCase() || "";
        let filtered = allProducts.filter(p => p.name.toLowerCase().includes(searchTerm) || p.category.toLowerCase().includes(searchTerm) || p.vendorName.toLowerCase().includes(searchTerm));
        const container = document.getElementById('marketplaceRoot');
        if (!container) return;
        if (allProducts.length === 0) {
            container.innerHTML = `<div class="empty-marketplace"><i class="fas fa-store"></i><h3>✨ Welcome to CreedMarket ✨</h3><p>Discover unique products from local merchants.</p><button id="quickApplyBtnEmpty" style="background:linear-gradient(95deg,#FFB347,#FF8C42); color:#1E2A2A;">Become a seller</button></div>`;
            document.getElementById('quickApplyBtnEmpty')?.addEventListener('click', () => document.getElementById('registerSellerModal').style.display = 'flex');
            return;
        }
        if(filtered.length === 0) { container.innerHTML = `<div class="empty-marketplace"><i class="fas fa-search"></i><p>No matching items.</p></div>`; return; }
        let gridHtml = `<div class="products-grid">`;
        filtered.forEach(prod => {
            gridHtml += `<div class="product-card"><div class="product-img">${prod.icon || '✨'}</div><div class="product-info"><div class="product-title">${escapeHtml(prod.name)}</div><div class="vendor-section"><span class="vendor-name"><i class="fas fa-store"></i> ${escapeHtml(prod.vendorName)}</span>${prod.vendorPhone ? getContactButtons(prod.vendorPhone) : ''}</div><div class="price">UGX ${prod.price.toLocaleString()}</div><div class="description" style="font-size:0.8rem; color:#5A6E66;">${escapeHtml(prod.description)}</div><button class="add-to-cart-item" data-id="${prod.id}"><i class="fas fa-cart-plus"></i> Add to cart</button></div></div>`;
        });
        gridHtml += `</div>`;
        container.innerHTML = gridHtml;
        document.querySelectorAll('.add-to-cart-item').forEach(btn => btn.addEventListener('click', (e) => addToCart(parseInt(btn.dataset.id))));
    }

    function escapeHtml(str) { return str.replace(/[&<>]/g, function(m){ if(m === '&') return '&amp;'; if(m === '<') return '&lt;'; if(m === '>') return '&gt;'; return m;});}
    function addToCart(prodId) { const prod = allProducts.find(p => p.id === prodId); if(prod) { let existing = shoppingCart.find(i => i.id === prodId); existing ? existing.quantity++ : shoppingCart.push({ id: prod.id, name: prod.name, price: prod.price, quantity: 1 }); syncStorage(); updateCartUI(); showToast(`✓ ${prod.name} added`); } }

    const cartModal = document.getElementById('cartModalGlobal');
    document.getElementById('cartBtnHeader').onclick = () => openCartModal();
    document.getElementById('closeCartModal').onclick = () => cartModal.style.display = 'none';
    function openCartModal() { let itemsHtml = "", total = 0; shoppingCart.forEach((item, idx) => { let itemSum = item.price * item.quantity; total += itemSum; itemsHtml += `<div style="display:flex; justify-content:space-between; border-bottom:1px solid #ffe0b5; padding:10px 0;"><div><strong>${item.name}</strong> x${item.quantity}</div><div>UGX ${itemSum.toLocaleString()} <button style="background:#FF8C42; padding:4px 12px;" onclick="removeCartItem(${idx})">✖</button></div></div>`; }); document.getElementById('cartItemsContainer').innerHTML = itemsHtml || "<p>Cart empty</p>"; document.getElementById('cartTotalAmount').innerHTML = `Total: UGX ${total.toLocaleString()}`; cartModal.style.display = 'flex'; }
    window.removeCartItem = (idx) => { shoppingCart.splice(idx,1); syncStorage(); updateCartUI(); openCartModal(); renderMarketplace(); };
    document.getElementById('realCheckoutBtn').onclick = () => { if(shoppingCart.length === 0) alert("Cart empty"); else { document.getElementById('orderStatusMsg').innerHTML = "<div style='background:#d1fae5; padding:12px; border-radius:28px;'>✅ Order placed! Vendors notified.</div>"; shoppingCart = []; syncStorage(); updateCartUI(); setTimeout(() => cartModal.style.display = 'none', 1800); renderMarketplace(); } };

    const regModal = document.getElementById('registerSellerModal');
    document.getElementById('sellerApplyNav').onclick = () => regModal.style.display = 'flex';
    document.getElementById('closeRegModalBtn').onclick = () => regModal.style.display = 'none';
    document.getElementById('submitPaymentRequestBtn').onclick = () => { let name = document.getElementById('regNameField').value.trim(); let phone = document.getElementById('regPhoneField').value.trim(); let txId = document.getElementById('regTransactionField').value.trim(); if(!name || !phone || !txId) alert("Fill all fields"); else if(approvedVendors.find(v=>v.phone===phone)) alert("Already approved"); else if(pendingVendors.find(v=>v.phone===phone)) alert("Pending already"); else { pendingVendors.push({ name, phone, transactionId: txId }); syncStorage(); document.getElementById('regMessageArea').innerHTML = "<span style='color:#2C5F4E;'>✔️ Request submitted.</span>"; setTimeout(() => regModal.style.display = 'none', 2000); } };

    const vendorModal = document.getElementById('vendorDashboardModal');
    document.getElementById('vendorDashNav').onclick = () => vendorModal.style.display = 'flex';
    document.getElementById('closeVendorDash').onclick = () => vendorModal.style.display = 'none';
    let currentVendorPhone = null;
    document.getElementById('vendorLoginAction').onclick = () => { let phone = document.getElementById('vendorPhoneLoginInput').value.trim(); let approved = approvedVendors.find(v => v.phone === phone); if(approved) { currentVendorPhone = phone; document.getElementById('vendorLoginSection').style.display = 'none'; document.getElementById('vendorInnerPanel').style.display = 'block'; loadVendorProducts(); } else alert("Not approved yet."); };
    function loadVendorProducts() { let myProducts = allProducts.filter(p => p.vendorPhone === currentVendorPhone); let container = document.getElementById('vendorProductsList'); if(container) { container.innerHTML = myProducts.map(prod => `<div style="background:#FEF7F0; padding:14px; border-radius:32px; margin-bottom:12px; display:flex; justify-content:space-between;"><div><span style="font-size:1.6rem;">${prod.icon || '✨'}</span> <strong>${prod.name}</strong><br><span style="font-weight:800;">UGX ${prod.price.toLocaleString()}</span></div><div><button class="edit-price-btn" data-editid="${prod.id}">✎ Price</button><button onclick="deleteVendorProduct(${prod.id})" style="background:#E67E22; margin-left:8px;">Remove</button></div></div>`).join(""); if(myProducts.length === 0) container.innerHTML = "<p>No products yet.</p>"; document.querySelectorAll('.edit-price-btn').forEach(btn => btn.addEventListener('click', (e) => openEditPriceModal(parseInt(btn.dataset.editid)))); } }
    window.deleteVendorProduct = (id) => { allProducts = allProducts.filter(p => p.id !== id); syncStorage(); loadVendorProducts(); renderMarketplace(); showToast("Removed"); };
    function openEditPriceModal(productId) { const product = allProducts.find(p => p.id === productId); if(product && product.vendorPhone === currentVendorPhone) { currentEditProductId = productId; document.getElementById('editProductNameDisplay').innerHTML = `Product: ${product.name}`; document.getElementById('editPriceInput').value = product.price; document.getElementById('editPriceModal').style.display = 'flex'; } }
    document.getElementById('closeEditModal').onclick = () => document.getElementById('editPriceModal').style.display = 'none';
    document.getElementById('confirmEditPriceBtn').onclick = () => { if(currentEditProductId) { let newPrice = parseInt(document.getElementById('editPriceInput').value); if(isNaN(newPrice) || newPrice <= 0) alert("Valid price"); else { let idx = allProducts.findIndex(p => p.id === currentEditProductId); if(idx !== -1 && allProducts[idx].vendorPhone === currentVendorPhone) { allProducts[idx].price = newPrice; syncStorage(); renderMarketplace(); loadVendorProducts(); document.getElementById('editPriceModal').style.display = 'none'; showToast("Price updated"); } } } };
    document.getElementById('publishProductBtn').onclick = () => { if(!currentVendorPhone) alert("Login first"); else { let name = document.getElementById('addProdName').value.trim(); let price = parseInt(document.getElementById('addProdPrice').value); let category = document.getElementById('addProdCategory').value; let desc = document.getElementById('addProdDesc').value.trim(); let icon = document.getElementById('addProdIcon').value.trim() || "✨"; if(!name || isNaN(price) || price <= 0) alert("Valid name & price"); else { let vendorInfo = approvedVendors.find(v => v.phone === currentVendorPhone); allProducts.push({ id: Date.now(), name, price, category, description: desc, icon, vendorPhone: currentVendorPhone, vendorName: vendorInfo ? vendorInfo.name : "Merchant" }); syncStorage(); renderMarketplace(); loadVendorProducts(); document.getElementById('addProdName').value = ""; document.getElementById('addProdPrice').value = ""; document.getElementById('addProdDesc').value = ""; showToast("Published!"); } } };

    const adminModal = document.getElementById('adminGlobalModal');
    document.getElementById('adminNavAccess').onclick = () => adminModal.style.display = 'flex';
    document.getElementById('closeAdminModal').onclick = () => adminModal.style.display = 'none';
    document.getElementById('adminLoginBtnGlobal').onclick = () => { if(document.getElementById('adminPasswordInput').value === ADMIN_CODE) { document.getElementById('adminSecureContent').style.display = 'block'; loadAdminDashboard(); } else alert("Wrong password"); };
    function loadAdminDashboard() { const pendingDiv = document.getElementById('pendingVendorsAdminList'); pendingDiv.innerHTML = pendingVendors.map((v, idx) => `<div style="background:#FFF4E6; padding:14px; border-radius:28px; margin-bottom:12px;"><strong>${v.name}</strong> | ${v.phone}<br><small>💰 ${v.transactionId}</small><br><button class="approve-btn" data-approveidx="${idx}">✓ Approve</button></div>`).join(""); document.querySelectorAll('[data-approveidx]').forEach(btn => btn.addEventListener('click', (e) => { let idx = parseInt(btn.dataset.approveidx); let vendor = pendingVendors[idx]; if(vendor) { approvedVendors.push({ name: vendor.name, phone: vendor.phone }); pendingVendors.splice(idx,1); syncStorage(); loadAdminDashboard(); renderMarketplace(); showToast(`✓ ${vendor.name} approved`); } })); document.getElementById('approvedVendorsAdminList').innerHTML = approvedVendors.map(v => `<div>✅ ${v.name} — ${v.phone}</div>`).join(""); }

    document.getElementById('homeBtnNav').onclick = () => { renderMarketplace(); window.scrollTo(0,0); };
    document.getElementById('globalSearchField').addEventListener('input', renderMarketplace);
    window.onclick = (e) => { if(e.target.classList.contains('modal')) e.target.style.display = 'none'; };
    renderMarketplace();
    updateCartUI();
</script>
</body>
